{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "touch /tmp/claude-chefgpt-edited"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f /tmp/claude-chefgpt-edited ] && rm /tmp/claude-chefgpt-edited && ./gradlew spotlessApply --quiet 2>/dev/null || true",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
